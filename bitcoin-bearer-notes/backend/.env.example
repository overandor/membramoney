# Application
APP_NAME=Membra Money API
DEBUG=false
ENV=production

# Solana (use devnet for devnet deploy)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# BTC Reserve
BTC_RESERVE_WALLET_XPUB=
BTC_RESERVE_MULTISIG_THRESHOLD=2
BTC_RESERVE_SIGNERS=3
BTC_NETWORK=testnet

# Database
DATABASE_URL=postgresql+asyncpg://coinpack:strong_password@db:5432/coinpack
REDIS_URL=redis://redis:6379/0

# Docker Compose database credentials (required for docker-compose.prod.yml)
POSTGRES_USER=coinpack
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=coinpack
REDIS_PASSWORD=change-this-to-a-strong-redis-password

# Security
SECRET_KEY=change-me-in-production-32-char-key-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=30
CLAIM_EXPIRATION_HOURS=24
PIN_PEPPER=change-me-pepper-32-char-long!!!
CLAIM_LINK_SECRET=change-me-claim-secret-32chars!!
ENCRYPTION_KEY=

# Reserve
MIN_RESERVE_RATIO_BPS=10000
MEMPOOL_API_BASE=https://mempool.space/testnet/api

# Frontend
FRONTEND_BASE_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com

# Delivery providers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=

# Rate limiting
RATE_LIMIT_AUTH=5
RATE_LIMIT_API=100
RATE_LIMIT_CLAIM=10

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
