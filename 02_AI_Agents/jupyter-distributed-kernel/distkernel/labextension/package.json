{
  "name": "jupyter-distributed-kernel",
  "version": "0.1.0",
  "description": "JupyterLab extension for distributed compute kernels",
  "keywords": ["jupyter", "jupyterlab", "jupyterlab-extension", "distributed", "kernel"],
  "license": "MIT",
  "files": ["lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}", "style/**/*.css"],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "jupyterlab": {
    "extension": true,
    "outputDir": "static"
  },
  "scripts": {
    "build": "tsc && webpack",
    "build:prod": "tsc && webpack --mode=production",
    "clean": "rimraf lib static tsconfig.tsbuildinfo",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/widgets": "^2.0.0",
    "@lumino/signaling": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "~5.2.0",
    "rimraf": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "ts-loader": "^9.0.0"
  }
}
