[Unit]
Description=DistKernel Notebook - 24/7 Distributed AI Notebook
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/path/to/jupyter-distributed-kernel
Environment="PATH=/usr/bin:/usr/local/bin"
ExecStart=/usr/bin/python3 /path/to/jupyter-distributed-kernel/distkernel_notebook.py --host 0.0.0.0 --port 8555
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Security
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
