# Gate.io API Credentials
GATE_API_KEY=your_gate_api_key_here
GATE_API_SECRET=your_gate_api_secret_here

# Ollama LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
USE_OLLAMA=1

# Trading Mode Configuration
PAPER_MODE=1
ARM_LIVE=NO
MARKET_MAKE_MODE=1
PROFIT_ONLY_MODE=0

# Daemon Configuration
DAEMON_MODE=1
MAX_RESTART_ATTEMPTS=10
RESTART_DELAY_SEC=5
HEALTH_CHECK_INTERVAL_SEC=60

# Market Making Configuration
MM_MAX_SYMBOLS=20
MM_ORDER_NOTIONAL_USD=1.00
MM_REFRESH_SEC=0.5
MM_MIN_SPREAD_BPS=1
MM_MAX_SPREAD_BPS=20
MM_QUOTE_EDGE_BPS=1.0
MM_MAX_POSITION_CONTRACTS=10
MM_INVENTORY_SKEW_BPS=8
MM_CANCEL_REPLACE_SEC=5
MM_MAX_OPEN_ORDERS_PER_SYMBOL=2
MM_STOP_LOSS_USD=2.00
MM_TAKE_PROFIT_USD=0.05
MM_REQUIRE_POST_ONLY=0
MM_ALLOW_SHORT=1
MM_ALLOW_LONG=1

# Trading Configuration
ORDER_NOTIONAL_USD=10
MAX_TOTAL_EXPOSURE_USD=100

# Risk Parameters
MAX_NOTIONAL_USD=10.00
MIN_VOLUME_USD=1000000
MAX_SYMBOLS=10
DEFAULT_LEVERAGE=3
MAX_EQUITY_PER_POS=0.02
MAX_TOTAL_EXPOSURE=0.30
FEE_RATE=0.00075
MARGIN_MODE=cross
