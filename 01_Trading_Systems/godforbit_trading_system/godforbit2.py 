
#!/usr/bin/env python3
from __future__ import annotations
import asyncio
import contextlib
import json
import math
import os
import signal
import time
from dataclasses import dataclass, asdict
from pathlib import Path
from typing import Any, Dict, List, Optional

import ccxt.async_support as ccxt
from rich.console import Console
from rich.table import Table

console = Console()

STATE_FILE = Path(os.getenv(\"STATE_FILE\", \"micro_bot_state.json\"))
SYMBOL_FILE = Path(os.getenv(\"SYMBOL_FILE\", \"micro_symbols.json\"))


@dataclass
class BotConfig:
    gate_api_key: str = os.getenv(\"GATE_API_KEY\", \"\")
    gate_api_secret: str = os.getenv(\"GATE_API_SECRET\", \"\")
    paper_mode: bool = os.getenv(\"PAPER_MODE\", \"true\").lower() == \"true\"

    settle: str = \"USDT\"
    default_type: str = \"swap\"
    margin_mode: str = os.getenv(\"MARGIN_MODE\", \"isolated\")
    leverage: int = int(os.getenv(\"LEVERAGE\", \"3\"))

    micro_max_price: float = float(os.getenv(\"MICRO_MAX_PRICE\", \"0.10\"))
    micro_min_price: float = float(os.getenv(\"MICRO_MIN_PRICE\", \"0.000001\"))
    max_symbols: int = int(os.getenv(\"MAX_SYMBOLS\", \"2\"))

    min_free_usdt: float = float(os.getenv(\"MIN_FREE_USDT\", \"25\"))
    max_margin_usage_pct: float = float(os.getenv(\"MAX_MARGIN_USAGE_PCT\", \"0.15\"))
    per_trade_margin_pct: float = float(os.getenv(\"PER_TRADE_MARGIN_PCT\", \"0.05\"))
    min_liq_buffer_pct: float = float(os.getenv(\"MIN_LIQ_BUFFER_PCT\", \"0.25\"))

    entry_cooldown_sec: int = int(os.getenv(\"ENTRY_COOLDOWN_SEC\", \"120\"))
    loop_delay_sec: float = float(os.getenv(\"LOOP_DELAY_SEC\", \"3\"))
    scan_interval_sec: int = int(os.getenv(\"SCAN_INTERVAL_SEC\", \"180\"))
    report_interval_sec: int = int(os.getenv(\"REPORT_INTERVAL_SEC\", \"20\"))

    signal_timeframe: str = os.getenv(\"SIGNAL_TIMEFRAME\", \"1m\")
    signal_lookback: int = int(os.getenv(\"SIGNAL_LOOKBACK\", \"30\"))
    fast_ma: int = int(os.getenv(\"FAST_MA\", \"5\"))
    slow_ma: int = int(os.getenv(\"SLOW_MA\", \"20\"))
    momentum_threshold_bps: float = float(os.getenv(\"MOMENTUM_THRESHOLD_BPS\", \"8\"))

    take_profit_pct: float = float(os.getenv(\"TAKE_PROFIT_PCT\", \"0.008\"))
    stop_loss_pct: float = float(os.getenv(\"STOP_LOSS_PCT\", \"0.004\"))
    max_position_age_sec: int = int(os.getenv(\"MAX_POSITION_AGE_SEC\", \"1800\"))

    limit_offset_bps: float = float(os.getenv(\"LIMIT_OFFSET_BPS\", \"2\"))


@dataclass
class PositionState:
    symbol: str
    side: str
    contracts: float
    entry_price: float
    opened_ts: float
    order_id: Optional[str] = None
    paper: bool = True


class GateMicroBot:
    def __init__(self, config: BotConfig):
        self.cfg = config
        self.exchange = None
        self.running = True
        self.selected_symbols: List[str] = []
        self.last_entry_ts: Dict[str, float] = {}
        self.paper_positions: Dict[str, PositionState] = {}
        self.pnl_by_symbol: Dict[str, float] = {}
        self.last_scan_ts = 0.0
        self.last_report_ts = 0.0

    async def initialize(self) -> None:
        if self.exchange is not None:
            return

        self.exchange = ccxt.gateio({
            \"apiKey\": self.cfg.gate_api_key,
            \"secret\": self.cfg.gate_api_secret,
            \"enableRateLimit\": True,
            \"options\": {
                \"defaultType\": self.cfg.default_type,
                \"defaultSettle\": self.cfg.settle.lower(),
                \"adjustForTimeDifference\": True,
                \"recvWindow\": 60000,
            },
        })
        await self.exchange.load_markets()
        self._load_state()
        self._install_signal_handlers()

    async def cleanup(self) -> None:
        if self.exchange is not None:
            with contextlib.suppress(Exception):
                await self.exchange.close()
        self._save_state()

    def _install_signal_handlers(self) -> None:
        def _stop(*_: Any) -> None:
            self.running = False

        with contextlib.suppress(NotImplementedError):
            signal.signal(signal.SIGINT, _stop)
            signal.signal(signal.SIGTERM, _stop)

    def _save_state(self) -> None:
        payload = {
            \"selected_symbols\": self.selected_symbols,
            \"last_entry_ts\": self.last_entry_ts,
            \"paper_positions\": {k: asdict(v) for k, v in self.paper_positions.items()},
            \"pnl_by_symbol\": self.pnl_by_symbol,
        }
        STATE_FILE.write_text(json.dumps(payload, indent=2))

    def _load_state(self) -> None:
        if not STATE_FILE.exists():
            return
        try:
            payload = json.loads(STATE_FILE.read_text())
            self.selected_symbols = list(payload.get(\"selected_symbols\", []))
            self.last_entry_ts = dict(payload.get(\"last_entry_ts\", {}))
            self.pnl_by_symbol = dict(payload.get(\"pnl_by_symbol\", {}))
            raw_positions = payload.get(\"paper_positions\", {})
            self.paper_positions = {
                sym: PositionState(**data) for sym, data in raw_positions.items()
            }
        except Exception as exc:
            console.print(f\"[yellow]Could not load state: {exc}[/yellow]\")

    async def get_free_usdt(self) -> float:
        if self.cfg.paper_mode:
            return float(os.getenv(\"PAPER_USDT_BALANCE\", \"1000\"))

        bal = await self.exchange.fetch_balance()
        free = float(
            bal.get(\"free\", {}).get(\"USDT\", 0)
            or bal.get(\"USDT\", {}).get(\"free\", 0)
            or 0
        )
        if free <= 0:
            total = float(bal.get(\"total\", {}).get(\"USDT\", 0) or 0)
            used = float(bal.get(\"used\", {}).get(\"USDT\", 0) or 0)
            free = max(total - used, 0)
        return free

    async def fetch_eligible_symbols(self) -> List[str]:
        free = await self.get_free_usdt()
        if free < self.cfg.min_free_usdt:
            console.print(
                f\"[yellow]Free USDT ${{free:.4f}} below minimum ${{self.cfg.min_free_usdt:.2f}}. No trading.[/yellow]\"
            )
            return []

        eligible: List[tuple[str, float, float]] = []

        for market in self.exchange.markets.values():
            symbol = market.get(\"symbol\")
            if not symbol:
                continue
            if not market.get(\"active\", True):
                continue
            if not market.get(\"swap\", False):
                continue

            quote = market.get(\"quote\")
            settle = market.get(\"settle\")
            if quote != \"USDT\" and settle != \"USDT\":
                continue

            try:
                ticker = await self.exchange.fetch_ticker(symbol, {\"type\": \"swap\"})
                last = float(ticker.get(\"last\") or 0)
                if not (self.cfg.micro_min_price <= last <= self.cfg.micro_max_price):
                    continue

                quote_volume = float(ticker.get(\"quoteVolume\") or 0)
                contract_size = float(market.get(\"contractSize\") or 1)
                contract_notional = last * contract_size
                contract_margin = contract_notional / max(self.cfg.leverage, 1)

                if contract_notional <= 0 or contract_margin <= 0:
                    continue

                max_margin_per_trade = free * self.cfg.per_trade_margin_pct
                if contract_margin > max_margin_per_trade:
                    continue

                eligible.append((symbol, quote_volume, contract_margin))
            except Exception:
                continue

        eligible.sort(key=lambda x: (-x[1], x[2]))
        chosen = [sym for sym, _, _ in eligible[: self.cfg.max_symbols]]
        SYMBOL_FILE.write_text(json.dumps(chosen, indent=2))
        return chosen

    async def refresh_symbol_universe_if_needed(self) -> None:
        now = time.time()
        if self.selected_symbols and now - self.last_scan_ts < self.cfg.scan_interval_sec:
            return
        symbols = await self.fetch_eligible_symbols()
        self.selected_symbols = symbols
        self.last_scan_ts = now
        if symbols:
            console.print(f\"[cyan]Selected symbols: {symbols}[/cyan]\")
        else:
            console.print(\"[yellow]No eligible symbols selected.[/yellow]\")

    async def set_leverage(self, symbol: str) -> None:
        if self.cfg.paper_mode:
            return
        with contextlib.suppress(Exception):
            await self.exchange.set_leverage(self.cfg.leverage, symbol, {\"type\": \"swap\"})

    async def fetch_mark_price(self, symbol: str) -> float:
        ticker = await self.exchange.fetch_ticker(symbol, {\"type\": \"swap\"})
        return float(ticker.get(\"mark\") or ticker.get(\"last\") or 0)

    async def fetch_signal(self, symbol: str) -> Optional[str]:
        try:
            ohlcv = await self.exchange.fetch_ohlcv(
                symbol,
                timeframe=self.cfg.signal_timeframe,
                limit=self.cfg.signal_lookback,
                params={\"type\": \"swap\"},
            )
            if len(ohlcv) < max(self.cfg.fast_ma, self.cfg.slow_ma) + 1:
                return None

            closes = [float(row[4]) for row in ohlcv if row and row[4] is not None]
            fast = sum(closes[-self.cfg.fast_ma:]) / self.cfg.fast_ma
            slow = sum(closes[-self.cfg.slow_ma:]) / self.cfg.slow_ma
            drift_bps = ((fast / slow) - 1.0) * 10000 if slow > 0 else 0.0
            threshold = self.cfg.momentum_threshold_bps

            if drift_bps >= threshold:
                return \"buy\"
            if drift_bps <= -threshold:
                return \"sell\"
            return None
        except Exception:
            return None

    async def estimate_contracts(self, symbol: str):
        free = await self.get_free_usdt()
        if free < self.cfg.min_free_usdt:
            return 0

        market = self.exchange.market(symbol)
        last = await self.fetch_mark_price(symbol)
        if last <= 0:
            return 0

        contract_size = float(market.get(\"contractSize\") or 1)
        contract_notional = last * contract_size
        contract_margin = contract_notional / max(self.cfg.leverage, 1)
        if contract_margin <= 0:
            return 0

        per_trade_budget = free * self.cfg.per_trade_margin_pct
        raw_contracts = per_trade_budget / contract_margin

        min_amount = float(market.get(\"limits\", {}).get(\"amount\", {}).get(\"min\") or 1)
        max_amount = float(market.get(\"limits\", {}).get(\"amount\", {}).get(\"max\") or raw_contracts)
        precision = int(market.get(\"precision\", {}).get(\"amount\", 0) or 0)

        if precision == 0:
            contracts = int(raw_contracts)
        else:
            factor = 10 ** precision
            contracts = math.floor(raw_contracts * factor) / factor

        contracts = max(min_amount, contracts)
        contracts = min(max_amount, contracts)

        projected_margin = contracts * contract_margin
        max_total_margin = free * self.cfg.max_margin_usage_pct

        if projected_margin <= 0 or projected_margin > max_total_margin:
            return 0

        if isinstance(contracts, float) and contracts.is_integer():
            return int(contracts)
        return int(contracts) if precision == 0 else contracts

    async def current_position(self, symbol: str) -> Optional[PositionState]:
        if self.cfg.paper_mode:
            return self.paper_positions.get(symbol)

        try:
            positions = await self.exchange.fetch_positions([symbol], {\"type\": \"swap\"})
            for p in positions:
                contracts = float(p.get(\"contracts\", 0) or 0)
                if contracts <= 0:
                    continue

                side = p.get(\"side\")
                entry_price = float(p.get(\"entryPrice\") or p.get(\"entry_price\") or 0)
                return PositionState(
                    symbol=symbol,
                    side=\"buy\" if side == \"long\" else \"sell\",
                    contracts=contracts,
                    entry_price=entry_price,
                    opened_ts=time.time(),
                    paper=False,
                )
            return None
        except Exception:
            return None

    async def liquidation_buffer_ok(self, symbol: str) -> bool:
        if self.cfg.paper_mode:
            return True
        try:
            positions = await self.exchange.fetch_positions([symbol], {\"type\": \"swap\"})
            for p in positions:
                contracts = float(p.get(\"contracts\", 0) or 0)
                if contracts <= 0:
                    continue

                liq = p.get(\"liquidationPrice\")
                mark = p.get(\"markPrice\") or p.get(\"info\", {}).get(\"mark_price\")
                side = p.get(\"side\")

                if liq is None or mark is None:
                    continue

                liq = float(liq)
                mark = float(mark)
                if liq <= 0 or mark <= 0:
                    continue

                if side == \"long\":
                    buffer_pct = (mark - liq) / mark
                else:
                    buffer_pct = (liq - mark) / mark

                if buffer_pct < self.cfg.min_liq_buffer_pct:
                    console.print(
                        f\"[yellow][{symbol}] Liq buffer {buffer_pct:.2%} below minimum {self.cfg.min_liq_buffer_pct:.2%}[/yellow]\"
                    )
                    return False
            return True
        except Exception:
            return True

    async def place_entry(self, symbol: str, side: str) -> bool:
        if time.time() - self.last_entry_ts.get(symbol, 0) < self.cfg.entry_cooldown_sec:
            return False

        if not await self.liquidation_buffer_ok(symbol):
            return False

        contracts = await self.estimate_contracts(symbol)
        if not contracts:
            return False

        price = await self.fetch_mark_price(symbol)
        if price <= 0:
            return False

        offset = self.cfg.limit_offset_bps / 10000.0
        limit_price = price * (1 - offset) if side == \"buy\" else price * (1 + offset)

        if self.cfg.paper_mode:
            self.paper_positions[symbol] = PositionState(
                symbol=symbol,
                side=side,
                contracts=float(contracts),
                entry_price=limit_price,
                opened_ts=time.time(),
                paper=True,
            )
            self.last_entry_ts[symbol] = time.time()
            console.print(f\"[green][PAPER] Open {side.upper()} {contracts} {symbol} @ {limit_price:.8f}[/green]\")
            return True

        await self.set_leverage(symbol)

        try:
            order = await self.exchange.create_limit_order(
                symbol,
                side,
                contracts,
                limit_price,
                {\"marginMode\": self.cfg.margin_mode, \"type\": \"swap\"},
            )
            self.last_entry_ts[symbol] = time.time()
            console.print(f\"[green]Open {side.upper()} {contracts} {symbol} @ {limit_price:.8f} ({order.get('id')})[/green]\")
            return True
        except Exception as exc:
            console.print(f\"[yellow][{symbol}] Entry failed: {exc}[/yellow]\")
            return False

    async def place_exit(self, pos: PositionState) -> bool:
        symbol = pos.symbol
        exit_side = \"sell\" if pos.side == \"buy\" else \"buy\"
        price = await self.fetch_mark_price(symbol)
        if price <= 0:
            return False

        offset = self.cfg.limit_offset_bps / 10000.0
        limit_price = price * (1 + offset) if pos.side == \"buy\" else price * (1 - offset)

        if self.cfg.paper_mode:
            pnl = self._paper_close_pnl(pos, limit_price)
            self.pnl_by_symbol[symbol] = self.pnl_by_symbol.get(symbol, 0.0) + pnl
            self.paper_positions.pop(symbol, None)
            console.print(f\"[magenta][PAPER] Close {symbol} @ {limit_price:.8f} pnl={pnl:.6f}[/magenta]\")
            return True

        try:
            await self.exchange.create_limit_order(
                symbol,
                exit_side,
                pos.contracts,
                limit_price,
                {\"marginMode\": self.cfg.margin_mode, \"reduceOnly\": True, \"type\": \"swap\"},
            )
            console.print(f\"[magenta]Close {symbol} {pos.contracts} @ {limit_price:.8f}[/magenta]\")
            return True
        except Exception as exc:
            console.print(f\"[yellow][{symbol}] Exit failed: {exc}[/yellow]\")
            return False

    def _paper_close_pnl(self, pos: PositionState, exit_price: float) -> float:
        if pos.side == \"buy\":
            return (exit_price - pos.entry_price) * pos.contracts
        return (pos.entry_price - exit_price) * pos.contracts

    async def manage_symbol(self, symbol: str) -> None:
        position = await self.current_position(symbol)

        if position is None:
            signal_side = await self.fetch_signal(symbol)
            if signal_side:
                await self.place_entry(symbol, signal_side)
            return

        mark = await self.fetch_mark_price(symbol)
        if mark <= 0:
            return

        age = time.time() - position.opened_ts
        if position.side == \"buy\":
            pnl_pct = (mark / position.entry_price) - 1.0
        else:
            pnl_pct = (position.entry_price / mark) - 1.0

        if pnl_pct >= self.cfg.take_profit_pct:
            await self.place_exit(position)
            return

        if pnl_pct <= -self.cfg.stop_loss_pct:
            await self.place_exit(position)
            return

        if age >= self.cfg.max_position_age_sec:
            await self.place_exit(position)
            return

    async def report(self) -> None:
        now = time.time()
        if now - self.last_report_ts < self.cfg.report_interval_sec:
            return
        self.last_report_ts = now

        free = await self.get_free_usdt()
        table = Table(title=\"Gate Micro Futures Refactor\")
        table.add_column(\"Mode\")
        table.add_column(\"Free USDT\")
        table.add_column(\"Symbols\")
        table.add_column(\"Open Positions\")
        table.add_column(\"Realized/Paper PnL\")

        total_pnl = sum(self.pnl_by_symbol.values())
        open_positions = len(self.paper_positions) if self.cfg.paper_mode else \"live\"
        table.add_row(
            \"PAPER\" if self.cfg.paper_mode else \"LIVE\",
            f\"{free:.4f}\",
            \", \".join(self.selected_symbols) if self.selected_symbols else \"-\",
            str(open_positions),
            f\"{total_pnl:.6f}\",
        )
        console.print(table)

    async def run(self) -> None:
        await self.initialize()
        console.print(
            f\"[bold cyan]Starting {'PAPER' if self.cfg.paper_mode else 'LIVE'} bot | \"
            f\"lev={self.cfg.leverage} | max_symbols={self.cfg.max_symbols} | \"
            f\"micro<=${self.cfg.micro_max_price}[/bold cyan]\"
        )

        while self.running:
            try:
                await self.refresh_symbol_universe_if_needed()
                for symbol in self.selected_symbols:
                    if not self.running:
                        break
                    await self.manage_symbol(symbol)
                    await asyncio.sleep(self.cfg.loop_delay_sec)
                await self.report()
                self._save_state()
                await asyncio.sleep(0.2)
            except Exception as exc:
                console.print(f\"[red]Main loop error: {exc}[/red]\")
                await asyncio.sleep(2)


async def main() -> None:
    cfg = BotConfig()
    bot = GateMicroBot(cfg)
    try:
        await bot.run()
    finally:
        await bot.cleanup()


if __name__ == \"__main__\":
    asyncio.run(main())
