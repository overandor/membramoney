{
  "version": 2,
  "builds": [
    {
      "src": "real_solana_miner.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "real_solana_miner.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.9"
  },
  "functions": {
    "real_solana_miner.py": {
      "runtime": "python3.9"
    }
  }
}
