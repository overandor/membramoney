GATE_API_KEY=
GATE_API_SECRET=
GATE_BASE_URL=https://fx-api.gateio.ws/api/v4
GATE_WS_URL=wss://fx-ws.gateio.ws/v4/ws/usdt
GATE_SETTLE=usdt

MODE=paper
SYMBOLS=DOGE_USDT,XRP_USDT,TRX_USDT
DB_PATH=gate_mm_beast.db
LOG_LEVEL=INFO

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

RISK_USD=15
LEVERAGE=2
BAR_INTERVAL=1m
BAR_LIMIT=400
LOOP_SECONDS=2
ENTRY_EDGE_BPS=5
TAKE_ATR_MULT=1.0
STOP_ATR_MULT=1.6

API_HOST=127.0.0.1
API_PORT=8788
ENABLE_API=true


# Live hardening
MAX_ABS_POSITION_PER_SYMBOL=100
MAX_TOTAL_OPEN_ORDERS=30
REPLACE_THRESHOLD_TICKS=1
BOOK_STALE_SECONDS=3.0
REST_BOOK_REFRESH_SECONDS=2.0
STARTUP_SYNC=true
CANCEL_ALL_ON_START=false
LIVE_ENABLE_TRADING=false
QUOTE_TIF=gtc
POST_ONLY_MODE=false
