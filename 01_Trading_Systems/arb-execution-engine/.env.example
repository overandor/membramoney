# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jito Endpoint
JITO_ENDPOINT=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# Burner Wallet Private Key (Base64 encoded)
# Generate with: python signer.py
BURNER_WALLET_PRIVATE_KEY=

# Execution Settings
MIN_EDGE_PCT=0.5  # Minimum edge percentage (0.5% - raised for reality)
MAX_PRIORITY_FEE=10000  # Maximum priority fee in lamports
FEE_PROFIT_RATIO=0.3  # Use 30% of expected profit for priority fee
KILL_SWITCH_THRESHOLD=-0.1  # Stop if losing more than 0.1 SOL in last N trades
KILL_SWITCH_TRADES=10  # Check last 10 trades for kill switch
EXECUTION_MODE=sim  # "sim" for simulation, "real" for mainnet execution

# API Key
API_KEY=dev_key_change_in_production  # API key for protected endpoints

# Gate.io
GATEIO_API_KEY=
GATEIO_API_SECRET=
MAX_RISK_PER_TRADE=0.02  # 2% risk per trade

# Legacy Settings (unused)
MIN_SPREAD_PCT=0.5
MAX_TRADES_PER_SCAN=5
SCAN_INTERVAL_SECONDS=10
TIP_LAMPORTS=10000
