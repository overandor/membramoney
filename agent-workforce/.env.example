# Agent Workforce Platform - Environment Variables

# App
APP_NAME=AgentWorkforce
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Email
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@agentworkforce.dev

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org

# Vercel
VERCEL_TOKEN=...
VERCEL_TEAM_ID=optional-team-id

# Redis
REDIS_URL=redis://localhost:6379/0

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/agentworkforce

# Sentry (optional)
SENTRY_DSN=https://...@sentry.io/...
