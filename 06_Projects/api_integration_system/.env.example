# Digital Gold Forge - API Credentials Configuration
# Copy this file to .env and fill in your actual API keys

# ====================
# AI/LLM Services
# ====================
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ====================
# Social Media Platforms
# ====================
# Twitter/X API Credentials
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# TikTok API Credentials
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_OPEN_ID=your_tiktok_open_id

# ====================
# Storage & IPFS
# ====================
# Pinata for IPFS
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Google Drive (Service Account JSON file path)
GOOGLE_DRIVE_CREDENTIALS=path/to/service_account.json

# ====================
# NFT Marketplaces
# ====================
# Zora Foundation
ZORA_API_KEY=your_zora_api_key

# OpenSea (optional)
OPENSEA_API_KEY=your_opensea_api_key

# Rarible (optional)
RARIBLE_API_KEY=your_rarible_api_key

# ====================
# Deployment Platforms
# ====================
# Replit API
REPLIT_API_KEY=your_replit_api_key

# Render API
RENDER_API_KEY=your_render_api_key

# Jules (Google AI Coding Agent)
JULES_API_KEY=your_jules_api_key

# ====================
# GitHub (for Actions & Repos)
# ====================
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
GITHUB_REPO=your_repo_name

# ====================
# Trading Bot Configuration
# ====================
# Gate.io
GATE_API_KEY=your_gate_api_key
GATE_SECRET_KEY=your_gate_secret_key

# Hyperliquid
HL_SECRET_KEY=your_hyperliquid_secret_key
HL_ACCOUNT_ADDRESS=your_hyperliquid_address

# ====================
# System Configuration
# ====================
# Digital Gold Forge Settings
DIGITAL_GOLD_OUTPUT_DIR=./digital_gold_output
DIGITAL_GOLD_LOG_DIR=./digital_gold_logs
DIGITAL_GOLD_AUTO_DEPLOY=true
DIGITAL_GOLD_MINT_NFTS=true
DIGITAL_GOLD_POST_TO_TWITTER=true
DIGITAL_GOLD_POST_TO_TIKTOK=true
