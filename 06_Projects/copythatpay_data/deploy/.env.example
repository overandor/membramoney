# CopyThatPay — Environment Variables
# Copy this to /Users/alep/Downloads/.env and fill in your keys

# Gate.io API (REQUIRED)
GATE_API_KEY=your_gate_api_key_here
GATE_API_SECRET=your_gate_api_secret_here

# Groq LLM API (OPTIONAL — used for symbol volatility scoring only)
GROQ_API_KEY=your_groq_api_key_here
