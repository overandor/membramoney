# Use a paid RPC if possible. Public RPC is weak for arb.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Live wallet. Use throwaway wallet only.
WALLET_KEYPAIR_PATH=/absolute/path/to/throwaway-wallet.json

# Kamino addresses. Do not guess.
KAMINO_MARKET_ADDRESS=PUT_REAL_KAMINO_MARKET_ADDRESS_HERE
KAMINO_USDC_RESERVE_ADDRESS=PUT_REAL_KAMINO_USDC_RESERVE_HERE

# Jupiter legacy endpoints used for custom instruction assembly.
# For newer deployments, migrate this to Jupiter Swap V2 /build.
JUPITER_QUOTE_URL=https://api.jup.ag/swap/v1/quote
JUPITER_SWAP_INSTRUCTIONS_URL=https://api.jup.ag/swap/v1/swap-instructions
JUPITER_API_KEY=

# Targets: WSOL, mSOL, jitoSOL, JUP, BONK
TARGET_MINTS=So11111111111111111111111111111111111111112,mSoLzYCxHdYgdzU16g5QSh3i5K3z3KZK7ytfqcJm7So,J1toso1uCk3RLmjorhTtrVwz9mqoSR72Hivzy1ZpQpm,JUPyiwrYJFskUPiHa7hkeR8VUtAeFoSYbKedZNsDvCN,DezXAZ8z7PnrnRJjz3JrSY7e8VUyTCSXjjuFvqFEpPB263

# USDC atoms. 1_000_000 = 1 USDC.
BORROW_SIZES_USDC_ATOMS=1000000,2000000,5000000,10000000,25000000,50000000

SLIPPAGE_BPS=15
MAX_PRICE_IMPACT_BPS=80
FLASH_LOAN_FEE_BPS=5
PRIORITY_FEE_USDC_ATOMS=100000
MIN_NET_PROFIT_USDC_ATOMS=300000
MIN_SIMULATED_PROFIT_USDC_ATOMS=200000

COMPUTE_UNIT_LIMIT=1350000
COMPUTE_UNIT_PRICE_MICRO_LAMPORTS=20000

MAX_QUOTE_AGE_MS=1500
SCAN_INTERVAL_MS=3000
MAX_TX_BYTES=1232

LIVE_SEND_ENABLED=false
REQUIRE_MANUAL_APPROVAL=true
MAX_SEND_RETRIES=3
CONFIRMATION_COMMITMENT=confirmed

PROOF_DIR=./proofs
