# ============================================================
# CLEANSTAT INFRASTRUCTURE - ENVIRONMENT CONFIGURATION
# ============================================================
# Production-hardened environment variables
# IMPORTANT: Copy this file to .env and fill in production values
# DO NOT commit .env to version control

# ============================================================
# APPLICATION
# ============================================================
ENVIRONMENT=production
DEBUG=false

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://cleanstat:CHANGE_ME@localhost:5432/cleanstat
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://:password@localhost:6379/0

# ============================================================
# SECURITY
# ============================================================
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_DOMAIN=
COOKIE_SECURE=true

# ============================================================
# IPFS (PINATA)
# ============================================================
PINATA_JWT=your_pinata_jwt_token_here
PINATA_GATEWAY=https://gateway.pinata.cloud

# ============================================================
# BLOCKCHAIN
# ============================================================
WEB3_PROVIDER_URI=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
VCU_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=100

# ============================================================
# MONITORING
# ============================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345
PROMETHEUS_ENABLED=true
