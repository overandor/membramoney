# MEMBRA CompanyOS — Production Environment

# Database
DATABASE_URL=postgresql://membra:membra@localhost:5432/membra_companyos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Security
SECRET_KEY=change-me-in-production-256-bit-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Ethereum / Wallet Auth
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=1

# LLM Providers
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile

# External Settlement
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=

# IPFS / Proof
IPFS_GATEWAY=https://gateway.pinata.cloud
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
ENVIRONMENT=development

# CompanyOS Defaults
DEFAULT_COMPANY_NAME=MEMBRA Autonomous Unit
DEFAULT_CURRENCY=USD
PROOFBOOK_HASH_ALGORITHM=sha3_256
GOVERNANCE_ADMIN_WALLET=
