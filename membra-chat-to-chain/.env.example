# MEMBRA — Chat-to-Chain Human Value Infrastructure
# Environment Variables
# Copy to .env and fill in values

# ============================================
# REQUIRED
# ============================================

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_PROGRAM_ID=your_program_id_here

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=overandor
GITHUB_REPO_NAME=chat-pipeline

# Pinata (IPFS)
PINATA_JWT=your_pinata_jwt_here
PINATA_GATEWAY=https://gateway.pinata.cloud

# ============================================
# OPTIONAL — DEV ONLY
# ============================================

# Devnet keypair path (local only, never committed)
DEVNET_KEYPAIR_PATH=~/.config/solana/id.json

# Database
DATABASE_URL=postgresql://membra:membra@localhost:5432/membra

# API
API_PORT=8000
API_HOST=0.0.0.0

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ============================================
# MAINNET — NEVER AUTO-SIGN
# ============================================

# Mainnet RPC (read-only for transaction preparation)
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Multisig PDA (if applicable)
MULTISIG_PDA=

# ============================================
# SECURITY
# ============================================

# NEVER commit private keys or seed phrases
# NEVER set MAINNET_PRIVATE_KEY
# All mainnet transactions require explicit human/multisig approval
